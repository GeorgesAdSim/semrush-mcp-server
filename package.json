{
  "name": "semrush-mcp-server",
  "version": "1.0.0",
  "description": "SEMrush API MCP Server for SEO analytics - Domain analysis, keyword research, backlinks, and traffic analytics",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "semrush-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "semrush",
    "seo",
    "keyword-research",
    "backlinks",
    "analytics",
    "claude",
    "ai"
  ],
  "author": "Georges Cordewiener <georges@adsim.be>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
